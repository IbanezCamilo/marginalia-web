# Backend API origin, WITHOUT the trailing /api (config.js appends /api itself).
# Also used to build image URLs. Vite inlines this at BUILD time.
# Prod example: https://api.readmarginalia.net
VITE_API_URL=http://localhost:8080

# Optional. Origin of the quotes edge Worker (quote of the day). Defaults to
# https://edge.readmarginalia.net when unset; the endpoint is public, so dev works without it.
# VITE_QUOTES_URL=https://edge.readmarginalia.net
